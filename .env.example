# Copy to .env and adjust. Docker Compose defaults match these values.

POSTGRES_USER=privateai
POSTGRES_PASSWORD=privateai
POSTGRES_DB=privateai

# Used by backend when run outside Docker (optional)
DATABASE_URL=postgresql://privateai:privateai@localhost:5432/privateai
QDRANT_URL=http://localhost:6333

JWT_SECRET=change-me-in-production
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme

# Uploaded originals stored under this directory (Compose mounts it for the backend)
UPLOAD_ROOT=./data/uploads

# Chat LLM: mock_llm (extractive only) or ollama (host must expose :11434; see docker-compose extra_hosts)
DEFAULT_LLM_PROVIDER=mock_llm
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
